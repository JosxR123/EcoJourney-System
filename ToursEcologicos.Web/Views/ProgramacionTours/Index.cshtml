@model IEnumerable<ToursEcologicos.Domain.Entities.ProgramacionTour>

@{
    ViewData["Title"] = "Programaciones";
}

<h1>Programaciones</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Crear nueva programación</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Tour</th>
            <th>Guia</th>
            <th>Fecha</th>
            <th>Hora de salida</th>
            <th>Cupos disponibles</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@(item.Tour != null ? item.Tour.Nombre : "")</td>
                <td>@(item.Guia != null ? item.Guia.Nombre : "")</td>
                <td>@item.Fecha.ToShortDateString()</td>
                <td>@item.HoraSalida</td>
                <td>@item.CuposDisponibles</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Detalles</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>