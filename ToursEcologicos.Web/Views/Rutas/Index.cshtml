@model IEnumerable<ToursEcologicos.Domain.Entities.Ruta>

@{
    ViewData["Title"] = "Rutas";
}

<h1>Rutas</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Crear nueva ruta</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre de ruta</th>
            <th>Ubicación</th>
            <th>Distancia (km)</th>
            <th>Dificultad</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.NombreRuta</td>
                <td>@item.Ubicacion</td>
                <td>@item.DistanciaKm</td>
                <td>@item.Dificultad</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Detalles</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>