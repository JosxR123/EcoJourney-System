@model ToursEcologicos.Domain.Entities.Reserva

@{
    ViewData["Title"] = "Editar reserva";
}

<h1>Editar reserva</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="ClienteId"></label>
                <select asp-for="ClienteId" class="form-control" asp-items="ViewBag.ClienteId"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ProgramacionTourId"></label>
                <select asp-for="ProgramacionTourId" class="form-control" asp-items="ViewBag.ProgramacionTourId"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CantidadPersonas"></label>
                <input asp-for="CantidadPersonas" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="FechaReserva"></label>
                <input asp-for="FechaReserva" type="date" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Estado"></label>
                <input asp-for="Estado" class="form-control" />
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Guardar cambios" class="btn btn-primary" />
            </div>
        </form>

        <div class="mt-3">
            <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
        </div>
    </div>
</div>